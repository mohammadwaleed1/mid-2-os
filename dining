#include <stdio.h>
#include <pthread.h>
#include <semaphore.h>
#include <unistd.h>

#define N 5 // Number of philosophers

sem_t chopsticks[N];

void* philosopher(void* num) {
    int id = *(int*)num;

    while (1) {
        printf("Philosopher %d is thinking...\n", id);
        sleep(1); 

        // --- Pick up chopsticks (Deadlock Prevention Logic) ---
        if (id % 2 == 0) {
            // Even philosophers: Right then Left
            sem_wait(&chopsticks[(id + 1) % N]);
            sem_wait(&chopsticks[id]);
        } else {
            // Odd philosophers: Left then Right
            sem_wait(&chopsticks[id]);
            sem_wait(&chopsticks[(id + 1) % N]);
        }

        // --- Eating Section ---
        printf("Philosopher %d is EATING\n", id);
        sleep(2); 

        // --- Put down chopsticks ---
        sem_post(&chopsticks[id]);
        sem_post(&chopsticks[(id + 1) % N]);
        
        printf("Philosopher %d finished eating and dropped chopsticks\n", id);
    }
    return NULL;
}

int main() {
    pthread_t threads[N];
    int ids[N];

    // Initialize semaphores (1 means the chopstick is available)
    for (int i = 0; i < N; i++) {
        sem_init(&chopsticks[i], 0, 1);
    }

    // Create 5 philosopher threads
    for (int i = 0; i < N; i++) {
        ids[i] = i;
        pthread_create(&threads[i], NULL, philosopher, &ids[i]);
    }

    // Join threads (keep program running)
    for (int i = 0; i < N; i++) {
        pthread_join(threads[i], NULL);
    }

    // Cleanup
    for (int i = 0; i < N; i++) {
        sem_destroy(&chopsticks[i]);
    }

    return 0;
}
